ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_CALENDAR_ID=primary
# Uncomment to enable email reply sending via voice command
# JARVIS_ALLOW_SEND=1

# ElevenLabs TTS (https://elevenlabs.io)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id_here

# OpenWeatherMap (https://openweathermap.org/api — free tier)
OPENWEATHER_API_KEY=your_openweathermap_api_key_here
OPENWEATHER_CITY=Valencia,ES
OPENWEATHER_UNITS=metric

# Spotify Web API (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Browser tabs opened at startup (appended to YouTube, Claude, Instagram)
ERP_URL=https://afosxsofa.expande.es/ERP/3.2/inicio/w3erp/index.php
# Optional: comma-separated full override of the entire startup tab list
# JARVIS_STARTUP_URLS=https://youtube.com,https://claude.ai,https://instagram.com,https://afosxsofa.expande.es/ERP/3.2/inicio/w3erp/index.php
